LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_THINKING_LEVEL=low
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LLM_MAX_OUTPUT_TOKENS=4096
LLM_TIMEOUT_SECONDS=30
PROMPT_PROFILE=balanced

# Optional deployment gate. When set, /api/ask requires this shared token.
APP_ACCESS_TOKEN=

# Optional: set these only if you want local dollar estimates in reports.
# Token counts are logged without these values.
GEMINI_INPUT_COST_PER_1M=
GEMINI_OUTPUT_COST_PER_1M=
OPENAI_INPUT_COST_PER_1M=
OPENAI_OUTPUT_COST_PER_1M=
